# deploy/.env.prod.example
# 复制为 deploy/.env.prod 并填实际值，勿入 git。
APP_ENV=prod
APP_SECRET_KEY=请用 `python -c "import secrets;print(secrets.token_urlsafe(48))"` 生成

DATABASE_URL=sqlite+aiosqlite:///./data/qinghe.db

OSS_ENDPOINT=oss-cn-hangzhou-internal.aliyuncs.com
OSS_BUCKET=qinghe-prod
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=cn-hangzhou

SHARE_DEFAULT_SECONDS=86400
SHARE_MIN_SECONDS=300
SHARE_MAX_SECONDS=2592000

SESSION_TTL_SECONDS=604800
PUBLIC_BASE_URL=https://qinghe.example.com
