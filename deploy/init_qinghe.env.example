# 复制本文件为同目录下的 init_qinghe.env 后填写，切勿提交到 git。
#   cp deploy/init_qinghe.env.example deploy/init_qinghe.env
#   chmod 600 deploy/init_qinghe.env
#
# 在 ECS 上项目克隆完成后执行（示例）：
#   sudo bash deploy/init_qinghe.sh

# ----- 目录（与 clone 路径一致）-----
APP_DIR=/var/www/qinghezhixing

# ----- systemd / 进程 -----
SERVICE_NAME=qinghe-backend
RUN_USER=www-data
RUN_GROUP=www-data
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ----- 站点 -----
PUBLIC_BASE_URL=https://your-domain.example
# 前后端不同域时填写浏览器访问前端的 Origin，逗号分隔；同域反向代理可留空
# CORS_ORIGINS=https://your-domain.example

# ----- 首个管理员（默认 root / admin1234，登录后请修改）-----
ADMIN_USER=root
ADMIN_PASS=admin1234

# ----- 阿里云 OSS（使用 RAM 子账号 AK，勿用主账号）-----
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_INTERNAL_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_REGION=cn-hangzhou
